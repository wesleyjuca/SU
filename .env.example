# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=afj
POSTGRES_PASSWORD=afj_secret_change_in_prod
POSTGRES_DB=afj_core
DATABASE_URL=postgresql+asyncpg://afj:afj_secret_change_in_prod@postgres:5432/afj_core

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_in_prod
REDIS_URL=redis://:redis_secret_change_in_prod@redis:6379/0

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ─── Segurança ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_CLAUDE_MODEL=claude-opus-4-7
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secret_change_in_prod@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret_change_in_prod@redis:6379/2

# ─── Polling de tribunais ─────────────────────────────────────────────────────
PROCESS_POLLING_INTERVAL_MINUTES=30
PROCESS_POLLING_BATCH_SIZE=50
PUBLICATION_SCAN_HOUR=7  # hora do scan diário (7h da manhã)

# ─── LGPD / Criptografia ──────────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-32-byte-key-in-production!

# ─── Ambiente ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
